<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  macOS launchd LaunchAgent for wispr_export.py — the Mac-local equivalent of
  the VPS's systemd timers (dayos-sync.timer, weekly-digest.timer), since
  Wispr Flow's database only exists on the Mac and this can't run on the VPS.

  Setup (run once, on the Mac, after wispr_export.py has been verified
  against the real database — see docs/BACKLOG.md "Still needs" 1-3):
    1. Replace the __REPO_PATH__ and __HOME__ placeholders below:
       sed -i '' "s|__REPO_PATH__|$PWD|g; s|__HOME__|$HOME|g" \
         deploy/com.instatank.wispr-export.plist
    2. cp deploy/com.instatank.wispr-export.plist ~/Library/LaunchAgents/
    3. launchctl load ~/Library/LaunchAgents/com.instatank.wispr-export.plist
    4. Check it ran: launchctl list | grep wispr-export
       Logs: ~/WisprFlowExports/launchd.log and launchd.err.log

  Cadence: StartInterval below runs every 6 hours (21600s), matching the
  DayOS/playbook sync cadence. To run once daily at a fixed time instead,
  delete the StartInterval key/value pair and add:
    <key>StartCalendarInterval</key>
    <dict><key>Hour</key><integer>21</integer><key>Minute</key><integer>0</integer></dict>

  To stop: launchctl unload ~/Library/LaunchAgents/com.instatank.wispr-export.plist
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.instatank.wispr-export</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/python3</string>
        <string>__REPO_PATH__/wispr_export.py</string>
    </array>

    <key>WorkingDirectory</key>
    <string>__REPO_PATH__</string>

    <key>StartInterval</key>
    <integer>21600</integer>

    <key>RunAtLoad</key>
    <false/>

    <key>StandardOutPath</key>
    <string>__HOME__/WisprFlowExports/launchd.log</string>

    <key>StandardErrorPath</key>
    <string>__HOME__/WisprFlowExports/launchd.err.log</string>
</dict>
</plist>
