# Copy to .env and fill in. Never commit the real .env.
TELEGRAM_BOT_TOKEN=paste-token-from-@BotFather
ANTHROPIC_API_KEY=paste-key-from-console.anthropic.com
TELEGRAM_ALLOWED_USER_ID=your-numeric-telegram-id
# Optional: daily spend ceiling in USD (default 0.50 = ~$15/month max)
DAILY_CAP_USD=0.50
# Web search: max searches per message ($0.01 each, counted in the daily cap).
# Set to 0 to disable web search entirely.
WEB_SEARCH_MAX_USES=3

# --- DayOS second brain (optional — the bot works fine without it) -----------
# Path to the Firebase service-account JSON for the DayOS project.
# Get it: Firebase console -> Project settings -> Service accounts ->
# Generate new private key. Then: chmod 600 the file.
FIREBASE_SERVICE_ACCOUNT_FILE=/opt/instatank-agent/.firebase-sa.json
# Your DayOS Firebase user id. Leave empty to auto-detect (works when the
# Firebase project has exactly one user — which it does).
DAYOS_UID=
# How many days back the frequent sync refreshes (a full re-pull runs daily anyway)
DAYOS_RECENT_DAYS=14

# --- Playbook memory bank (optional — the bot works fine without it) ----------
# Git URL of the repo holding the playbook/ folder + LEARNINGS.md. Setting this
# turns the playbook bank on; leave empty to keep it off.
PLAYBOOK_REPO_URL=https://github.com/instatank/time-tracker.git
# Only needed if that repo is private: a fine-grained GitHub token with
# read-only Contents permission on that ONE repo.
# GitHub -> Settings -> Developer settings -> Fine-grained tokens.
PLAYBOOK_REPO_TOKEN=
# Branch to mirror (default main)
PLAYBOOK_REPO_BRANCH=main
